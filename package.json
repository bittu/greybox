{
  "name": "greybox",
  "version": "0.1.1",
  "description": "Flake belongs in pastry. Not in CI. AI-powered natural language E2E testing for React Native with Detox sync.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' 'tests/**/*.ts' --fix",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'",
    "test": "jest",
    "prepare": "husky",
    "release": "release-it",
    "release:dry": "release-it --dry-run",
    "prepublishOnly": "npm run lint && npm run build && npm test"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "detox",
    "react-native",
    "testing",
    "ai",
    "llm",
    "e2e",
    "natural-language",
    "accessibility",
    "automation"
  ],
  "author": "bittu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bittu/greybox.git"
  },
  "bugs": {
    "url": "https://github.com/bittu/greybox/issues"
  },
  "homepage": "https://github.com/bittu/greybox#readme",
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.100.0",
    "@aws-sdk/client-bedrock-runtime": ">=3.0.0",
    "detox": ">=20.0.0"
  },
  "peerDependenciesMeta": {
    "detox": {
      "optional": false
    },
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "@aws-sdk/client-bedrock-runtime": {
      "optional": true
    }
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "domhandler": "^5.0.3",
    "htmlparser2": "^9.1.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1075.0",
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@release-it/conventional-changelog": "^11.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "detox": ">=20.0.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "prettier": "^3.8.4",
    "release-it": "^20.2.0",
    "ts-jest": "^29.4.11",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.62.0"
  }
}
